{
  "name": "mycollections-desktop-app",
  "productName": "mycollections-desktop-app",
  "version": "1.0.0",
  "description": "My Electron application description",
  "main": ".webpack/main",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "yarn; yarn clean; electron-forge make;rm -rf .webpack",
    "publish": "electron-forge publish",
    "assert-database-env": "ts-node -r dotenv/config scripts/assert-database-env.cts",
    "prestart": "yarn assert-database-env",
    "lint": "eslint --ext .ts,.tsx .",
    "lint:fix": "eslint --ext .ts,.tsx . --fix",
    "lint-changed": "node scripts/eslint-changed.ts",
    "lint-changed-fix": "node scripts/eslint-changed.ts --fix",
    "check-changed": "node scripts/check-changed.ts",
    "typecheck": "tsc",
    "typecheck-changed": "node scripts/typecheck-changed.ts",
    "clean": "rm -rf .webpack && rm -rf out",
    "open-mac": "out/mycollections-desktop-app-darwin-x64/mycollections-desktop-app.app/Contents/MacOS/mycollections-desktop-app",
    "make-open-mac": "yarn make; yarn open-mac",
    "premake": "yarn assert-database-env",
    "prettify": "exec prettier . --write --log-level=warn",
    "prettify-changed": "node scripts/prettify-changed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "which-prisma-db": "bash check-prisma-db-url.sh"
  },
  "author": {
    "name": "Aleksandr Pasharin",
    "email": "aleksandr.pasharin@columbiaroad.com"
  },
  "prisma": {
    "schema": "./prisma/schema"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-deb": "^7.8.1",
    "@electron-forge/maker-rpm": "^7.8.1",
    "@electron-forge/maker-squirrel": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.1",
    "@electron-forge/plugin-fuses": "^7.8.1",
    "@electron-forge/plugin-webpack": "^7.8.1",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^9.30.1",
    "@stylistic/eslint-plugin": "^5.1.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "@vercel/webpack-asset-relocator-loader": "1.7.3",
    "copy-webpack-plugin": "^13.0.0",
    "css-loader": "^6.0.0",
    "css-modules-typescript-loader": "^4.0.1",
    "electron": "37.2.0",
    "eslint": "^9.30.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fork-ts-checker-webpack-plugin": "^7.2.13",
    "jest": "^30.3.0",
    "node-loader": "^2.0.0",
    "postcss": "^8.5.15",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.7.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^6.17.1",
    "style-loader": "^3.0.0",
    "tailwindcss": "^4.3.0",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.2.2",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "^3.15.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1"
  },
  "dependencies": {
    "@prisma/client": "^6.17.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "dotenv": "^17.0.1",
    "electron-squirrel-startup": "^1.0.1",
    "kysely": "^0.28.4",
    "pg": "^8.16.3",
    "prisma-kysely": "^1.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "uuid": "^11.1.0",
    "yaml": "^2.9.0",
    "zod": "^4.3.6"
  }
}
