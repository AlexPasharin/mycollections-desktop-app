# The three LOCAL_* / REMOTE_* URLs are required before the Electron app builds or starts (validated in src/config/database-urls.ts).
# Copy to .env and set each URL.

# Postgres on your machine you use during feature development / experiments
LOCAL_DEV_DB_URL=

# Postgres on your machine that mirrors production data (default Kysely source)
LOCAL_PROD_DB_URL=

# Hosted production Postgres
REMOTE_PROD_DB_URL=

# URL used by Prisma migrations and `prisma generate` (see prisma/schema/schema.prisma)
PRISMA_DB_URL=
